// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite" // Changed from postgresql
  url      = "file:./dev.db" // Changed from env("DATABASE_URL")
}

model User {
  id                      Int       @id @default(autoincrement())
  email                   String    @unique
  password                String // Will store the hashed password
  isConfirmed             Boolean   @default(false)
  confirmationToken       String?
  confirmationTokenExpiry DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  userFamilies UserFamily[] // Relation to the UserFamily join table
}

model Family {
  id        Int      @id @default(autoincrement())
  name      String? // Optional name for the family, e.g., "The Simpsons Family"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  familyMembers FamilyMember[] // Relation to FamilyMember
  userFamilies  UserFamily[] // Relation to the UserFamily join table
}

// Join table for User and Family (many-to-many)
model UserFamily {
  userId    Int
  familyId  Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  // role   String?  // Optional: e.g., "admin", "member" for role-based access within a family
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, familyId])
}

model FamilyMember {
  id         Int       @id @default(autoincrement())
  fullName   String
  gender     String // Consider using an Enum if your DB supports it
  birthDate  DateTime? // Removed @db.Date
  deathDate  DateTime? // Removed @db.Date
  birthPlace String?
  picture    Bytes? // Changed from pictureUrl String?

  // Self-referencing relations for parents
  parentId1 Int?
  parentId2 Int?

  // Define the relation to self for children
  children1 FamilyMember[] @relation("Parent1Children")
  children2 FamilyMember[] @relation("Parent2Children")

  // Define the relation fields for parents (optional, improves clarity)
  parent1 FamilyMember? @relation("Parent1Children", fields: [parentId1], references: [id], onDelete: SetNull, onUpdate: Cascade)
  parent2 FamilyMember? @relation("Parent2Children", fields: [parentId2], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Add relation to User
  // Relation to Family
  familyId Int
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId]) // Add index for querying by family
}
