// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite" // Changed from postgresql
  url      = "file:./dev.db" // Changed from env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String    // Will store the hashed password
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  familyMembers FamilyMember[] // Relation to FamilyMember
}

model FamilyMember {
  id         Int       @id @default(autoincrement())
  fullName   String
  gender     String // Consider using an Enum if your DB supports it
  birthDate  DateTime? // Removed @db.Date
  deathDate  DateTime? // Removed @db.Date
  birthPlace String?
  pictureUrl String?

  // Self-referencing relations for parents
  parentId1 Int?
  parentId2 Int?

  // Define the relation to self for children
  children1 FamilyMember[] @relation("Parent1Children")
  children2 FamilyMember[] @relation("Parent2Children")

  // Define the relation fields for parents (optional, improves clarity)
  parent1   FamilyMember? @relation("Parent1Children", fields: [parentId1], references: [id], onDelete: SetNull, onUpdate: Cascade)
  parent2   FamilyMember? @relation("Parent2Children", fields: [parentId2], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Add relation to User
  userId Int
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade) // Add onDelete: Cascade

  @@index([userId]) // Add index for querying by user
}
